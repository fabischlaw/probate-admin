    {
      "type": "draw",
      "text": "I hereby certify that, except as noted in paragraph 3 below, none of the following:  The Personal Representative named in the Will, the Special Personal Representative whose appointment is sought, the person(s) who has requested to be appointed or been proposed as a Personal Representative or, any person proposed to replace the Personal Representative who has resigned or been removed, did feloniously and intentionally kill the Decedent.",
      "x": "9.525mm",
      "y": "3.175mm",
      "parentPath": "form1.BodyPage1.S2",
      "name": "StaticText6",
      "w": "190.5mm",
      "h": "19.05mm"
    },
    {
      "type": "draw",
      "text": "I hereby certify that, except as noted in paragraph 3 below, no person who is entitled to a share in the estate either under the Will itself or by operation of law, by descent or distribution, elective share, omitted spouse or child's share, exempt property, family allowance or through a share of the Decedent's property as a joint tenant or tenant by the entirety, did feloniously and intentionally kill the Decedent.",
      "x": "9.525mm",
      "y": "25.4mm",
      "parentPath": "form1.BodyPage1.S2",
      "name": "StaticText6",
      "w": "190.5mm",
      "h": "19.05mm"
    },
    {
      "type": "draw",
      "text": "2.",
      "x": "3.175mm",
      "y": "25.4mm",
      "parentPath": "form1.BodyPage1.S2",
      "name": "StaticText6",
      "w": "6.35mm",
      "h": "6.3500mm"
    },
    {
