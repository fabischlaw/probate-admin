# DecisionVault API
DV_API_KEY=your_decisionvault_api_key_here
DV_BASE_URL=https://api.decisionvault.com/v1

# Session security — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=generate_a_long_random_string_here

# AI Features (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_MODE=disabled

# Server
PORT=3000
NODE_ENV=production

# Data directory — override for Railway Volume persistence
# Mount a Volume at /app/data in Railway, then set:
# DATA_DIR=/app/data
DATA_DIR=
